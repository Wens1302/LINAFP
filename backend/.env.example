# Copier ce fichier en .env et renseigner les valeurs pour votre environnement.
#
# IMPORTANT – encodage du fichier sur Windows :
#   Enregistrez le fichier .env en UTF-8 (dans Notepad : Fichier > Enregistrer sous
#   > Encodage : UTF-8). Un encodage ANSI / CP1252 peut provoquer une
#   UnicodeDecodeError dans psycopg2 si le mot de passe contient des caractères
#   accentués. Si votre mot de passe contient des caractères spéciaux, utilisez
#   le percent-encodage :
#     python -c "from urllib.parse import quote; print(quote('votre_motdepasse', safe=''))"

# URL de connexion PostgreSQL
# Format : postgresql://<user>:<password>@<host>:<port>/<database>
# Laisser vide pour utiliser SQLite (développement uniquement)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gabonfootstats

# Origines CORS autorisées (séparées par des virgules)
# Laisser * pour autoriser toutes les origines (développement uniquement)
CORS_ORIGINS=*

# Clé secrète JWT – à changer absolument en production
JWT_SECRET_KEY=changeme-super-secret-key-for-dev

# Durée de validité des tokens JWT (en minutes, défaut : 480 = 8h)
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Identifiants de l'administrateur par défaut (à changer en production)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin1234
