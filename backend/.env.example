# Copy this file to .env and fill in the values for your environment.
# IMPORTANT: Save the .env file with UTF-8 encoding (in Notepad: File > Save As
# > Encoding: UTF-8).  Saving in another encoding (e.g. ANSI / CP1252) can
# cause a UnicodeDecodeError when psycopg2 parses the connection URL.
#
# If your password contains special characters (e.g. @, /, #, or accented
# letters), percent-encode them.  For example: 'é' → '%C3%A9'.
# You can generate percent-encoded values with:
#   python -c "from urllib.parse import quote; print(quote('your_password', safe=''))"

# PostgreSQL connection URL
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/linafp

# Comma-separated list of allowed CORS origins.
# Leave empty to allow all origins (development only).
# Example: ALLOWED_ORIGINS=https://myapp.example.com,https://admin.example.com
ALLOWED_ORIGINS=
